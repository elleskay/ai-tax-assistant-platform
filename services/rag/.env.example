# Copy to .env and fill in. The service reads these from the process environment.

# Required for real embeddings (text-embedding-3-small).
# For offline tests you can instead set RAG_FAKE_EMBEDDINGS=1 and omit this.
OPENAI_API_KEY=sk-...

# Postgres connection string with the pgvector extension enabled.
# If UNSET, the service automatically falls back to a local file-persisted
# vector store under ./.data (zero external dependencies).
# Neon example:
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# HTTP port the server binds to.
PORT=8000

# --- Optional tuning (defaults shown) ---
# RAG_EMBED_MODEL=text-embedding-3-small
# RAG_EMBED_DIM=1536
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=64
# RAG_DATA_DIR=./.data

# --- Test only ---
# RAG_FAKE_EMBEDDINGS=1   # use deterministic offline embeddings (no API key/network)
